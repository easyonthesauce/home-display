# Local-LAN access to Tuya energy monitors. No cloud account needed at runtime,
# but you DO need each device's local key (see README "Getting local keys").
#
# Format per device (comma-separated):
#   id:localKey:Label[:ip]
# IP is optional — if omitted the server auto-discovers via UDP broadcast,
# which only works if the server is on the same LAN subnet as the device.
TUYA_DEVICES=bf1234567890abcd:abcdef0123456789:Main Panel,bfabcdef12345678:fedcba9876543210:Solar:192.168.1.42

# Tuya local protocol version. Most devices made after ~2020 are 3.3 or 3.4.
# If you see connection failures, try the other one.
TUYA_PROTOCOL_VERSION=3.3

# How often to ask the device for a full DP refresh (ms). Push updates still
# arrive between refreshes; this is the safety-net polling interval.
REFRESH_INTERVAL_MS=5000

# How often to push a snapshot to connected browsers (ms).
BROADCAST_INTERVAL_MS=1000

# Override the default DP-index → code mapping if your meter uses a non-standard
# schema. Inspect each card's "raw DPs" in the dashboard footer to discover
# which index is which, then map them to the codes metrics.js understands
# (cur_power, cur_voltage, cur_current, add_ele, phase_a/b/c, frequency,
# power_factor). JSON object keyed by DP index as a string.
#
# Example: TUYA_DPS_OVERRIDES={"5":"cur_power","6":"cur_voltage","7":"cur_current"}
TUYA_DPS_OVERRIDES=

# Port the dashboard server listens on
PORT=3000


# ============================================================================
# Watchtower — security-camera analysis service (npm run watch)
# Independent of the Tuya dashboard above; only needed if you run watchtower.
# ============================================================================

# Anthropic API key for the vision + argument analysis (get one at
# https://console.anthropic.com/). Without it, watchtower still runs but uses
# mock analysis. The dashboard makes NO Claude calls directly — only the server.
ANTHROPIC_API_KEY=

# Models. Vision runs on each motion trigger; escalation runs every few seconds
# during a raised-voices event, so it defaults to a faster/cheaper model.
VISION_MODEL=claude-opus-4-8
ESCALATION_MODEL=claude-haiku-4-5

# Cameras: JSON array, or put them in watchtower/cameras.json (see the .example).
# Each: { "name": "...", "rtsp": "rtsp://user:pass@ip:554/...", "audio": true,
#         "trigger": "keyword the NVR puts in the email recipient/subject" }
WATCH_CAMERAS=

# Household roster used to identify people. JSON array, or watchtower/roster.json.
# Each: { "name": "Alex", "description": "dad, tall, beard, usually a grey hoodie" }
WATCH_ROSTER=

# Which camera's audio to analyse during a raised-voices event (defaults to the
# first camera). Use a camera id / slug.
WATCH_AUDIO_CAMERA=

# Default periodic "auto trigger" interval in seconds, applied to every camera
# that doesn't set its own "autoTriggerSeconds" in cameras.json. Runs a scene
# analysis on a timer, independent of motion/SMTP triggers — useful for a
# steady vibe/mess trend even when nobody walks past the camera. 0 (default)
# disables it. Values below 15s are clamped up to avoid hammering the camera
# and burning API calls. Adjustable per-camera at runtime from the dashboard
# (or POST /api/trigger/auto) without restarting.
WATCH_AUTO_TRIGGER_SECONDS=0

# Local speech-to-text command for near-realtime transcription. {file} is
# replaced with the WAV path (else it's appended). Left blank, the argument
# meter tracks raw loudness only. Keep this LOCAL so household audio stays on
# your network. Example (whisper.cpp):
#   TRANSCRIBE_CMD=/opt/whisper.cpp/main -m /opt/whisper.cpp/models/ggml-base.en.bin -nt -f {file}
TRANSCRIBE_CMD=

# Event webhooks: comma-separated URLs that receive a POST for every event
# (scene.update, audio.update, alert.child, incident.recorded, ...).
WATCH_WEBHOOKS=

# ── Alexa Bridge (announcements) ────────────────────────────────────────────
# Watchtower can announce alerts through Alexa devices via a separate sidecar
# service ("Alexa Bridge" — a small alexa-remote2-based HTTP API that owns the
# Amazon login/cookie; Watchtower is only ever a client of it, never talks to
# Amazon directly). Run that service on its own (see its own README), then
# point Watchtower at it here.
ALEXA_BRIDGE_URL=http://localhost:3000
ALEXA_BRIDGE_TIMEOUT_MS=8000

# Alert rules live in watchtower/alerts.json (cp alerts.json.example to start)
# — which events announce, on which device, with what message, how often.
# These two only provide defaults for rules that don't set their own
# "device" / "cooldownSeconds"; ALEXA_ALERTS_ENABLED=0 disables the feature
# entirely without touching alerts.json.
ALEXA_ALERTS_ENABLED=1
ALEXA_DEFAULT_DEVICE=all
ALEXA_DEFAULT_COOLDOWN_SECONDS=120

# Fake-SMTP motion trigger. Point your camera/NVR's "email on motion" at
# SMTP_BIND:SMTP_PORT with encryption OFF. Port 2525 avoids needing root; use
# 25 if your NVR insists on it (run with privileges or a port redirect).
SMTP_PORT=2525
SMTP_BIND=0.0.0.0
SMTP_HOSTNAME=watchtower.local

# Capture tuning
CLIP_SECONDS=10
FRAME_COUNT=8
AUDIO_CHUNK_SECONDS=5

# Port the watchtower dashboard listens on
WATCH_PORT=4000

# Path to ffmpeg if it isn't on PATH
# FFMPEG_PATH=/usr/bin/ffmpeg

# Logging verbosity: error | warn | info (default) | debug.
# debug logs every ffmpeg invocation, SMTP line, HTTP request, WebSocket
# broadcast, and Claude call timing/usage — useful when diagnosing a flaky
# camera or a slow analysis call, noisy for normal operation.
# LOG_LEVEL=debug
# Shorthand for LOG_LEVEL=debug:
# WATCH_VERBOSE=1
