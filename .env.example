# Local-LAN access to Tuya energy monitors. No cloud account needed at runtime,
# but you DO need each device's local key (see README "Getting local keys").
#
# Format per device (comma-separated):
#   id:localKey:Label[:ip]
# IP is optional — if omitted the server auto-discovers via UDP broadcast,
# which only works if the server is on the same LAN subnet as the device.
TUYA_DEVICES=bf1234567890abcd:abcdef0123456789:Main Panel,bfabcdef12345678:fedcba9876543210:Solar:192.168.1.42

# Tuya local protocol version. Most devices made after ~2020 are 3.3 or 3.4.
# If you see connection failures, try the other one.
TUYA_PROTOCOL_VERSION=3.3

# How often to ask the device for a full DP refresh (ms). Push updates still
# arrive between refreshes; this is the safety-net polling interval.
REFRESH_INTERVAL_MS=5000

# How often to push a snapshot to connected browsers (ms).
BROADCAST_INTERVAL_MS=1000

# Override the default DP-index → code mapping if your meter uses a non-standard
# schema. Inspect each card's "raw DPs" in the dashboard footer to discover
# which index is which, then map them to the codes metrics.js understands
# (cur_power, cur_voltage, cur_current, add_ele, phase_a/b/c, frequency,
# power_factor). JSON object keyed by DP index as a string.
#
# Example: TUYA_DPS_OVERRIDES={"5":"cur_power","6":"cur_voltage","7":"cur_current"}
TUYA_DPS_OVERRIDES=

# Port the dashboard server listens on
PORT=3000


# ============================================================================
# Watchtower — security-camera analysis service (npm run watch)
# Independent of the Tuya dashboard above; only needed if you run watchtower.
# ============================================================================

# ── LLM provider (vision + argument analysis) ───────────────────────────────
# Which backend powers the two Claude/GPT calls: scene analysis (vision, runs
# on each motion trigger) and escalation classification (runs every few
# seconds during a raised-voices event, so it wants a fast/cheap model).
# Without a configured provider, watchtower still runs but uses mock analysis.
# The dashboard (browser) makes NO LLM calls directly — only the server does.
#
#   anthropic          — Claude, via ANTHROPIC_API_KEY (default)
#   openai             — OpenAI, or ANY OpenAI-compatible /chat/completions
#                         endpoint (Azure OpenAI, Ollama, LM Studio, vLLM,
#                         Groq, OpenRouter, ...) via OPENAI_BASE_URL
LLM_PROVIDER=anthropic

# Get a key at https://console.anthropic.com/. Used when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=

# Used when LLM_PROVIDER=openai. Leave OPENAI_BASE_URL blank for api.openai.com.
# Point it at a local server instead to run fully offline, e.g.:
#   OPENAI_BASE_URL=http://localhost:11434/v1   (Ollama)
#   OPENAI_BASE_URL=http://localhost:1234/v1    (LM Studio)
# Local servers usually need no key at all.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_TIMEOUT_MS=30000

# Models — provider-specific IDs. If unset, sensible per-provider defaults are
# used (claude-opus-4-8 / claude-haiku-4-5 for anthropic, gpt-4o / gpt-4o-mini
# for openai) — but set these explicitly for a local/self-hosted model, e.g.
# VISION_MODEL=llama3.2-vision, ESCALATION_MODEL=llama3.2:1b.
VISION_MODEL=
ESCALATION_MODEL=

# Cameras: JSON array, or put them in watchtower/cameras.json (see the .example).
# Each: { "name": "...", "rtsp": "rtsp://user:pass@ip:554/...", "audio": true,
#         "trigger": "keyword the NVR puts in the email recipient/subject" }
WATCH_CAMERAS=

# Household roster used to identify people. JSON array, or watchtower/roster.json.
# Each: { "name": "Alex", "description": "dad, tall, beard, usually a grey hoodie" }
WATCH_ROSTER=

# Which camera's audio to analyse during a raised-voices event (defaults to the
# first camera). Use a camera id / slug.
WATCH_AUDIO_CAMERA=

# Default periodic "auto trigger" interval in seconds, applied to every camera
# that doesn't set its own "autoTriggerSeconds" in cameras.json. Runs a scene
# analysis on a timer, independent of motion/SMTP triggers — useful for a
# steady vibe/mess trend even when nobody walks past the camera. 0 (default)
# disables it. Values below 15s are clamped up to avoid hammering the camera
# and burning API calls. Adjustable per-camera at runtime from the dashboard
# (or POST /api/trigger/auto) without restarting.
WATCH_AUTO_TRIGGER_SECONDS=0

# Local speech-to-text command for near-realtime transcription. {file} is
# replaced with the WAV path (else it's appended). Left blank, the argument
# meter tracks raw loudness only. Keep this LOCAL so household audio stays on
# your network. Example (whisper.cpp):
#   TRANSCRIBE_CMD=/opt/whisper.cpp/main -m /opt/whisper.cpp/models/ggml-base.en.bin -nt -f {file}
TRANSCRIBE_CMD=

# Event webhooks: comma-separated URLs that receive a POST for every event
# (scene.update, audio.update, alert.child, incident.recorded, ...).
WATCH_WEBHOOKS=

# ── Alexa Bridge (announcements) ────────────────────────────────────────────
# Watchtower can announce alerts through Alexa devices via a separate sidecar
# service ("Alexa Bridge" — a small alexa-remote2-based HTTP API that owns the
# Amazon login/cookie; Watchtower is only ever a client of it, never talks to
# Amazon directly). Run that service on its own (see its own README), then
# point Watchtower at it here.
ALEXA_BRIDGE_URL=http://localhost:3000
ALEXA_BRIDGE_TIMEOUT_MS=8000

# Alert rules live in watchtower/alerts.json (cp alerts.json.example to start)
# — which events announce, on which device, with what message, how often.
# These two only provide defaults for rules that don't set their own
# "device" / "cooldownSeconds"; ALEXA_ALERTS_ENABLED=0 disables the feature
# entirely without touching alerts.json.
ALEXA_ALERTS_ENABLED=1
ALEXA_DEFAULT_DEVICE=all
ALEXA_DEFAULT_COOLDOWN_SECONDS=120

# ── Face enrolment + recognition (display webcam) ───────────────────────────
# Opt-in biometric feature. When enabled, the kitchen display uses its own
# webcam to recognise enrolled household members and shows a "have we met?"
# prompt to enrol an unrecognised person — only after they consent. All face
# processing happens in the browser; only 128-number face signatures (never
# images) are stored, locally in watchtower/faces.json, and never leave the LAN.
# NOTE: browsers only allow webcam access over HTTPS or on localhost, so run
# the display's browser on the same box as the server (http://localhost:4000)
# or serve Watchtower over HTTPS.
FACES_ENABLED=0
# Match strictness — Euclidean distance below which a live face matches an
# enrolled one. Lower is stricter; ~0.5 is the usual sweet spot.
FACES_MATCH_THRESHOLD=0.5
# How many face samples to capture during enrolment.
FACES_ENROLL_SAMPLES=5
# How long an unknown face must linger (ms) before "have we met?" appears, so
# passers-by and guests aren't prompted the instant they're seen.
FACES_UNKNOWN_DWELL_MS=4000

# ── Water Challenge (hydration game + ESP32 dispenser) ──────────────────────
# Adds a rotating "Water Challenge" page: opted-in family members get a
# droplet swimlane that fills toward a daily goal, a big Drink button that runs
# a 12V pump via an ESP32 + relay (measured with a flow meter), and a
# leaderboard. Off by default.
WATER_ENABLED=0
# Per-person daily hydration goal (ml) — fills the droplet lanes.
WATER_DAILY_GOAL_ML=2000
# Safety cutoffs for a single pour. The ESP32 firmware enforces its own limits
# on top of these — never trust the network to stop a pump.
WATER_MAX_POUR_ML=1000
WATER_MAX_POUR_SECONDS=60
# ESP32 dispenser URL (from the serial monitor after flashing the sketch in
# watchtower/esp32/). Leave BLANK to run in mock mode — pours are simulated so
# the whole game works and is testable without any hardware.
WATER_ESP32_URL=
WATER_ESP32_TIMEOUT_MS=4000
# Simulated flow rate used only in mock mode (ml per second).
WATER_MOCK_FLOW_ML_PER_SEC=50

# ── Dear Diary (wake-word video diary → Google Drive) ───────────────────────
# Off by default. When enabled, the display listens (in-browser, via the Web
# Speech API) for the wake word, prompts "are you ready?", counts down, then
# records up to DIARY_MAX_SECONDS of webcam video and uploads it.
DIARY_ENABLED=0
# Phrase that activates a new entry (case-insensitive substring match).
DIARY_WAKE_WORD=dear diary
# How long the big countdown dot counts down before recording starts.
DIARY_COUNTDOWN_SECONDS=5
# Hard cap on a single entry's length.
DIARY_MAX_SECONDS=60
# On-screen prompts for anyone stuck on what to say, pipe-separated. Leave
# blank to use the built-in defaults (what did you do today, how are you
# feeling, tell a joke/story, show something interesting, ...).
DIARY_SUGGESTIONS=

# Google Drive upload. Create a service account in Google Cloud Console,
# generate a JSON key, paste the whole thing (as one line) into
# GOOGLE_SERVICE_ACCOUNT_JSON, then share the destination Drive folder with
# the service account's client_email (from that JSON) as an Editor and put
# its folder ID here. Without both of these, entries are still recorded
# locally on the display but never leave the device.
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
# Manifest file kept alongside the videos in the Drive folder, listing every
# entry (filename, link, timestamp, duration).
GOOGLE_DRIVE_INDEX_FILENAME=dear-diary-index.json

# ── Google Tasks (quick view + Trello-style board page) ─────────────────────
# Off by default. Adds a "due soon" widget to the watch page and a dedicated
# "Tasks" page with one drag-and-drop column per Google task list.
#
# Tasks is per-user data, so (unlike Dear Diary's Drive upload) this needs an
# interactive OAuth consent flow rather than a service account:
#   1. In Google Cloud Console, create an OAuth 2.0 Client ID of type
#      "Web application", and add the redirect URI below (adjust host/port
#      to match where this server is actually reachable) as an authorized
#      redirect URI.
#   2. Enable the "Google Tasks API" for the project.
#   3. Paste the client ID + secret below and start the server.
#   4. Visit GET /api/tasks/auth/status on this server (or open the "connect
#      Google Tasks" button on the dashboard) to get the consent URL, sign in
#      once, and the refresh token is stored locally from then on
#      (watchtower/tasks-tokens.json — never commit this file).
TASKS_ENABLED=0
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/tasks/oauth/callback
# How often (seconds) to poll Google Tasks for changes made elsewhere (phone,
# Gmail, Calendar). Edits made on this dashboard apply immediately either way.
TASKS_POLL_SECONDS=60
# A task counts as "due soon" on the quick-view widget once it's within this
# many hours of its due date (overdue tasks always qualify).
TASKS_DUE_SOON_HOURS=48
# Max rows shown in the watch page's quick-view widget.
TASKS_QUICK_VIEW_LIMIT=6

# Fake-SMTP motion trigger. Point your camera/NVR's "email on motion" at
# SMTP_BIND:SMTP_PORT with encryption OFF. Port 2525 avoids needing root; use
# 25 if your NVR insists on it (run with privileges or a port redirect).
SMTP_PORT=2525
SMTP_BIND=0.0.0.0
SMTP_HOSTNAME=watchtower.local

# Capture tuning
CLIP_SECONDS=10
FRAME_COUNT=8
AUDIO_CHUNK_SECONDS=5

# Port the watchtower dashboard listens on
WATCH_PORT=4000

# Path to ffmpeg if it isn't on PATH
# FFMPEG_PATH=/usr/bin/ffmpeg

# RTSP transport ffmpeg uses to pull frames/audio. Defaults to tcp, which is
# what most cameras/NVRs expect. If capture fails with "Output file does not
# contain any stream" and the RTSP URL/credentials are confirmed correct, the
# camera may only support UDP — try setting this to udp.
# FFMPEG_RTSP_TRANSPORT=tcp

# Logging verbosity: error | warn | info (default) | debug.
# debug logs every ffmpeg invocation, SMTP line, HTTP request, WebSocket
# broadcast, and Claude call timing/usage — useful when diagnosing a flaky
# camera or a slow analysis call, noisy for normal operation.
# LOG_LEVEL=debug
# Shorthand for LOG_LEVEL=debug:
# WATCH_VERBOSE=1
