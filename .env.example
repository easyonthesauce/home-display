# Local-LAN access to Tuya energy monitors. No cloud account needed at runtime,
# but you DO need each device's local key (see README "Getting local keys").
#
# Format per device (comma-separated):
#   id:localKey:Label[:ip]
# IP is optional — if omitted the server auto-discovers via UDP broadcast,
# which only works if the server is on the same LAN subnet as the device.
TUYA_DEVICES=bf1234567890abcd:abcdef0123456789:Main Panel,bfabcdef12345678:fedcba9876543210:Solar:192.168.1.42

# Tuya local protocol version. Most devices made after ~2020 are 3.3 or 3.4.
# If you see connection failures, try the other one.
TUYA_PROTOCOL_VERSION=3.3

# How often to ask the device for a full DP refresh (ms). Push updates still
# arrive between refreshes; this is the safety-net polling interval.
REFRESH_INTERVAL_MS=5000

# How often to push a snapshot to connected browsers (ms).
BROADCAST_INTERVAL_MS=1000

# Override the default DP-index → code mapping if your meter uses a non-standard
# schema. Inspect each card's "raw DPs" in the dashboard footer to discover
# which index is which, then map them to the codes metrics.js understands
# (cur_power, cur_voltage, cur_current, add_ele, phase_a/b/c, frequency,
# power_factor). JSON object keyed by DP index as a string.
#
# Example: TUYA_DPS_OVERRIDES={"5":"cur_power","6":"cur_voltage","7":"cur_current"}
TUYA_DPS_OVERRIDES=

# Port the dashboard server listens on
PORT=3000
