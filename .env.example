# Tuya IoT Platform credentials
# Get these from https://iot.tuya.com/  →  Cloud → Development → your project → Overview
TUYA_CLIENT_ID=your_access_id_here
TUYA_CLIENT_SECRET=your_access_secret_here

# Data center your project is linked to.
# Options: us | eu | cn | in | ueaz (Western America)
TUYA_REGION=eu

# Comma-separated list of device IDs to read.
# Find them in the IoT Platform under Cloud → Devices, or via the Smart Life app.
# Optionally label each one: id:Label,id2:Label2
TUYA_DEVICE_IDS=bf1234567890abcd:Main Panel,bfabcdef12345678:Solar

# Polling interval in milliseconds (Tuya rate-limits aggressive polling)
POLL_INTERVAL_MS=2000

# Port the dashboard server listens on
PORT=3000
